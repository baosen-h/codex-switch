{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Switch Mini",
  "version": "0.1.0",
  "identifier": "com.baosenh.codex-switch-mini",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Switch Mini",
        "width": 1440,
        "height": 920,
        "minWidth": 1200,
        "minHeight": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/codex-switch-mini.png"
    ]
  }
}
